{
  "manifest_version": 3,
  "name": "hTab - Tab Manager & System Monitor",
  "version": "1.0.0",
  "description": "An interactive htop-style terminal and system monitor for browser tabs on your new tab page.",
  "permissions": [
    "tabs"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open hTab"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
